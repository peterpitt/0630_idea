# ── Supabase ──────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 僅後端 / Worker 使用，勿外洩

# ── Gemini (AI 辨識 + 食譜) ────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── LINE Messaging API ────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# ── 金流 ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
ECPAY_MERCHANT_ID=your-ecpay-merchant-id
ECPAY_HASH_KEY=your-ecpay-hash-key
ECPAY_HASH_IV=your-ecpay-hash-iv

# ── 前端（Vite 需 VITE_ 前綴）─────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
